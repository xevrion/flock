{
  "name": "@xevrion/flock-core",
  "version": "0.2.0",
  "description": "Framework-agnostic real-time presence & cursor transport for Flock",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xevrion/flock.git",
    "directory": "packages/core"
  },
  "homepage": "https://flock.xevrion.dev",
  "keywords": [
    "flock",
    "presence",
    "cursors",
    "multiplayer",
    "websocket",
    "real-time"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
