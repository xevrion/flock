{
  "name": "@xevrion/flock-react",
  "version": "0.2.0",
  "description": "React hooks adapter for Flock real-time presence & cursors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xevrion/flock.git",
    "directory": "packages/react"
  },
  "homepage": "https://flock.xevrion.dev",
  "keywords": [
    "flock",
    "presence",
    "cursors",
    "multiplayer",
    "react",
    "hooks",
    "real-time"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "dependencies": {
    "@xevrion/flock-core": "workspace:^"
  },
  "devDependencies": {
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0",
    "ws": "^8.18.0"
  }
}
